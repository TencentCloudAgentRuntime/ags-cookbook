# Option A — APIKey mode (quick start; no Tencent Cloud account required beyond an AGS API key)
E2B_API_KEY=your_ags_api_key
E2B_DOMAIN=ap-guangzhou.tencentags.com

# Option B — AKSK mode (production; sandbox lifecycle managed through the Tencent Cloud AGS control plane)
# When both sets are defined, AKSK mode takes precedence (see ags_client.credential_mode()).
# TENCENTCLOUD_SECRET_ID=your_secret_id
# TENCENTCLOUD_SECRET_KEY=your_secret_key
# TENCENTCLOUD_REGION=ap-guangzhou
